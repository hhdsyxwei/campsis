-- K线数据区块状态表 - 仅记录完成/未完成两种状态（复合主键）
CREATE TABLE IF NOT EXISTS `{{ table_name | default('kline_block_status') }}` (
  `{{ col_std_stock_code | default('std_stock_code') }}` VARCHAR(20) NOT NULL COMMENT '股票代码',
  `{{ col_time_frame | default('time_frame') }}` VARCHAR(20) 
    NOT NULL DEFAULT '5m' COMMENT '时间周期',
  `{{ col_quarter | default('quarter') }}` VARCHAR(7) NOT NULL COMMENT '季度 格式：YYYY-Qn，如2024-Q1',
  
  -- 核心状态字段：仅两种状态
  `{{ col_status | default('status') }}` ENUM('not_completed', 'skipped', 'completed', 'error') 
    NOT NULL DEFAULT 'not_completed' COMMENT '状态：not_completed-未完成，skipped-已跳过，completed-已完成，error-下载异常',
  `{{ col_completed_at | default('completed_at') }}` TIMESTAMP NULL COMMENT '数据下载完成时间',

  -- 自动维护时间戳
  `{{ col_create_time | default('create_time') }}` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '记录创建时间',
  `{{ col_update_time | default('update_time') }}` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '记录更新时间',

  -- 复合主键：股票+周期+季度 唯一标识一条记录
  PRIMARY KEY (`{{ col_std_stock_code | default('std_stock_code') }}`, `{{ col_time_frame | default('time_frame') }}`, `{{ col_quarter | default('quarter') }}`)
) ENGINE=InnoDB 
DEFAULT CHARSET=utf8mb4 
COLLATE=utf8mb4_unicode_ci 
COMMENT='K线数据区块下载状态表 | 仅记录未完成/完成状态 | 复合主键唯一索引';

-- 查看表结构
DESCRIBE `{{ table_name | default('kline_block_status') }}`;