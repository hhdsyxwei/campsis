-- 全局进度指针表 DDL
CREATE TABLE IF NOT EXISTS `{{ table_name | default('global_download_progress') | safe }}` (
  `{{ col_id | default('id') | safe }}` TINYINT UNSIGNED NOT NULL AUTO_INCREMENT COMMENT '主键',
  `{{ col_task_type | default('task_type') | safe }}` VARCHAR(20) NOT NULL COMMENT '任务类型（如：kline、xrxd、daily等）',
  `{{ col_primary_pointer_name | default('primary_pointer_name') | safe }}` VARCHAR(50) NOT NULL DEFAULT '' COMMENT '主进度指示器名称（如：quarter、year、date等）',
  `{{ col_primary_pointer_value | default('primary_pointer_value') | safe }}` VARCHAR(50) NOT NULL DEFAULT '' COMMENT '主进度指示器值（如：2024-Q1、2024、2024-01-01等）',
  `{{ col_secondary_pointer_name | default('secondary_pointer_name') | safe }}` VARCHAR(50) NOT NULL DEFAULT '' COMMENT '次级进度指示器名称（如：stock_code、code等）',
  `{{ col_secondary_pointer_value | default('secondary_pointer_value') | safe }}` VARCHAR(50) NOT NULL DEFAULT '' COMMENT '次级进度指示器值（如：sh.600000、000001.SZ等）',
  `{{ col_tertiary_pointer_name | default('tertiary_pointer_name') | safe }}` VARCHAR(50) NOT NULL DEFAULT '' COMMENT '三级进度指示器名称（如：time_frame、period等）',
  `{{ col_tertiary_pointer_value | default('tertiary_pointer_value') | safe }}` VARCHAR(50) NOT NULL DEFAULT '' COMMENT '三级进度指示器值（如：5m、1h、1d等）',
  `{{ col_update_time | default('update_time') | safe }}` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  PRIMARY KEY (`{{ pk_col | default('id') | safe }}`),
  UNIQUE KEY `uk_task_type` (`{{ col_task_type | default('task_type') | safe }}`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='全局进度指针表 | 用于重启续传、单向推进';
