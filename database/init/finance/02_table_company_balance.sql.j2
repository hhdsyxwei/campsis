/* ====================== 公司偿债能力数据表 ====================== */
CREATE TABLE IF NOT EXISTS `{{ table_name | default('company_balance') | safe }}` (
    `{{ col_id | default('id') | safe }}` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键ID',
    `{{ col_std_stock_code | default('std_stock_code') | safe }}` varchar(20) NOT NULL COMMENT '股票代码',
    `{{ col_pub_date | default('pub_date') | safe }}` date NOT NULL COMMENT '公司发布财报的日期',
    `{{ col_stat_date | default('stat_date') | safe }}` date NOT NULL COMMENT '财报统计的季度的最后一天',
    `{{ col_current_ratio | default('current_ratio') | safe }}` decimal(10,4) COMMENT '流动比率',
    `{{ col_quick_ratio | default('quick_ratio') | safe }}` decimal(10,4) COMMENT '速动比率',
    `{{ col_cash_ratio | default('cash_ratio') | safe }}` decimal(10,4) COMMENT '现金比率',
    `{{ col_yoy_liability | default('yoy_liability') | safe }}` decimal(10,4) COMMENT '总负债同比增长率(%)',
    `{{ col_liability_to_asset | default('liability_to_asset') | safe }}` decimal(10,4) COMMENT '资产负债率(%)',
    `{{ col_asset_to_equity | default('asset_to_equity') | safe }}` decimal(10,4) COMMENT '权益乘数',
    `{{ col_create_time | default('create_time') | safe }}` timestamp DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    `{{ col_update_time | default('update_time') | safe }}` timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
    PRIMARY KEY (`{{ col_id | default('id') | safe }}`),
    UNIQUE KEY `uk_std_stock_stat_date` (`{{ col_std_stock_code | default('std_stock_code') | safe }}`, `{{ col_stat_date | default('stat_date') | safe }}`),
    INDEX `idx_std_stock_code` (`{{ col_std_stock_code | default('std_stock_code') | safe }}`),
    INDEX `idx_stat_date` (`{{ col_stat_date | default('stat_date') | safe }}`),
    INDEX `idx_date_range` (`{{ col_std_stock_code | default('std_stock_code') | safe }}`, `{{ col_stat_date | default('stat_date') | safe }}`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='公司偿债能力数据表';
