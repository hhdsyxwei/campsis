# ==============================================================================
# 【核心规则 - Python 运行/编译产物】
# 此类文件由 Python 自动生成，无提交价值，且跨环境不兼容
# ==============================================================================
# Python 编译后的字节码缓存目录（3.x 版本），不同Python版本编译结果不同，必忽略
__pycache__/
# Python 2.x 编译产物（.pyc/.pyo/.pyd）和跨平台编译的.class文件，无需提交
*.py[cod]
*$py.class
# 单个.py文件编译后的字节码文件（兜底规则）
*.pyc

# ==============================================================================
# 【核心规则 - 打包/分发产物】
# 此类文件是项目构建/发布时生成的，仅发布阶段需要，无需纳入版本控制
# ==============================================================================
# setuptools/poetry 打包生成的分发包目录（如.tar.gz/.whl文件）
dist/
# setuptools 构建过程中生成的临时目录
build/
# Python egg 包的元信息目录（旧版打包格式）
*.egg-info/
# 单个egg包文件
*.egg
.eggs/
# wheel 打包产物目录
wheelhouse/
# 单个wheel包文件
*.whl

# ==============================================================================
# 【核心规则 - 虚拟环境】
# 虚拟环境是本地开发环境，每个开发者的依赖/路径不同，绝对不能提交
# ==============================================================================
# 常见的虚拟环境目录命名（通用/venv/conda 等）
venv/
env/
ENV/
.venv/  # poetry/pipenv 默认虚拟环境目录
.env/
env.local/  # 本地开发专用虚拟环境
env.test/   # 测试环境专用虚拟环境
# conda 虚拟环境目录（按需保留）
# envs/

# ==============================================================================
# 【核心规则 - 数据/缓存/日志】
# 此类文件通常体积大、易变，或含临时数据，无需提交
# ==============================================================================
# 数据库文件（SQLite 为主，量化项目常用本地数据库）
*.db
*.sqlite3
*.sqlite3-journal  # SQLite 事务日志
# 日志文件（量化项目会产生大量交易/回测日志）
*.log
logs/  # 日志目录
# pytest 测试缓存（含测试结果/覆盖率临时文件）
.pytest_cache/
# coverage 测试覆盖率报告文件
.coverage
htmlcov/  # coverage 生成的HTML版覆盖率报告
# Python 通用缓存目录
.cache/
# 量化项目专属 - 序列化数据文件（如策略参数、行情数据）
*.pkl
*.pickle
# 量化项目专属 - HDF5 大数据文件（行情/回测数据，体积通常很大）
*.h5
*.hdf5
# 量化项目专属 - 回测结果目录（临时/易变，无需共享）
backtest_results/
backtest_tmp/
# 数据分析项目专属 - 临时数据文件
*.csv.bak
*.xlsx.bak
data/raw/  # 原始数据（体积大、无需版本控制）
data/tmp/  # 临时处理数据

# ==============================================================================
# 【编辑器/IDE 配置】
# 此类文件是本地编辑器的个性化配置，跨开发者不兼容，仅保留团队共享配置
# ==============================================================================
# VS Code 配置目录（默认忽略）
.vscode/
# 例外：保留团队共享的 VS Code 配置（按需开启，去掉#即可）
# !.vscode/settings.json    # 共享的代码格式化/解释器配置
# !.vscode/extensions.json # 共享的必装插件列表
# !.vscode/tasks.json       # 共享的构建/运行任务
# !.vscode/launch.json     # 共享的调试配置

# PyCharm 配置目录（含本地调试/运行配置，必忽略）
.idea/
*.iml  # PyCharm 模块文件
*.iws  # PyCharm 工作区状态文件
*.ipr  # PyCharm 项目文件
out/   # PyCharm 编译输出目录

# Sublime Text 配置文件
*.sublime-project
*.sublime-workspace

# Vim 编辑器临时文件
*.swp  # 交换文件
*.swo  # 交换文件（备份）
.*.sw? # 所有交换文件变体
.un~   # 撤销文件

# Emacs 编辑器临时文件
*~     # 备份文件
\#*\#  # 自动保存文件
/.emacs.desktop
/.emacs.desktop.lock
*.elc  # 编译后的Emacs Lisp文件
auto-save-list/
tramp/
.\#*

# ==============================================================================
# 【操作系统缓存/垃圾文件】
# 此类文件由操作系统自动生成，无任何项目价值
# ==============================================================================
# macOS 系统文件
.DS_Store               # 文件夹属性文件
.AppleDouble            # macOS 隐藏文件
.LSOverride             # 权限覆盖文件
Icon                    # 自定义图标文件
._*                     # macOS 资源分支文件
.DocumentRevisions-V100 # 文档修订记录
.fseventsd              # 文件系统事件日志
.Spotlight-V100         #  Spotlight 索引
.TemporaryItems         # 临时文件
.Trashes                # 废纸篓
.VolumeIcon.icns        # 卷标图标
.com.apple.timemachine.donotpresent # TimeMachine 排除标记

# Windows 系统文件
Thumbs.db               # 缩略图缓存
ehthumbs.db             # 增强缩略图缓存
Desktop.ini             # 文件夹自定义配置
$RECYCLE.BIN/           # 回收站
*.cab                   # 安装包
*.msi                   # 安装包
*.msix                  # 安装包
*.msm                   # 安装包模块
*.msp                   # 安装包补丁
*.lnk                   # 快捷方式

# Linux 系统文件
*~                      # 备份文件
.fuse_hidden*           # FUSE 隐藏文件
.directory              # KDE 目录配置
.Trash-*                # 废纸篓
.nfs*                   # NFS 临时文件

# ==============================================================================
# 【敏感信息/本地配置】
# 此类文件含密钥、密码等敏感信息，或本地个性化配置，绝对不能提交
# ==============================================================================
# 本地配置文件（量化项目常含API密钥、数据库密码）
config/local_config.py
config/secrets.py
# .env 文件（环境变量，常用 python-dotenv 加载，含敏感信息）
.env
.env.local
.env.*.local  # 所有环境的本地覆盖配置
# 量化项目专属 - API密钥目录
api_keys/
api_secrets/
# 私钥文件
*.pem
*.key

# ==============================================================================
# 【自定义规则 - 按需添加】
# 以下可根据你的项目补充，示例为量化/数据分析项目常用规则
# ==============================================================================
# 示例1：Jupyter Notebook 检查点（临时文件）
# .ipynb_checkpoints/
# 示例2：模型文件（体积大，建议用模型仓库管理）
# *.pth
# *.pt
# models/
# 示例3：临时脚本/测试文件
# test_*.py
# tmp_*.py